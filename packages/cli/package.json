{
  "name": "damian",
  "description": "Easy migrations and typesafe queries with raw SQL",
  "author": "Fernando Coelho",
  "homepage": "https://damiandb.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fgcoelho/damian.git"
  },
  "keywords": [
    "migration",
    "query",
    "sql",
    "typesafe"
  ],
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.8",
  "license": "MIT",
  "type": "module",
  "bin": {
    "damian": "./dist/index.cjs"
  },
  "main": "./dist/runtime.cjs",
  "types": "./dist/runtime.d.cts",
  "exports": {
    ".": "./dist/runtime.cjs",
    "./cli": "./dist/index.cjs"
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/runtime.d.cts"
      ],
      "cli": [
        "./dist/index.d.cts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "oclif": {
    "bin": "damian",
    "dirname": "damian",
    "commands": {
      "strategy": "explicit",
      "target": "./dist/index.cjs",
      "identifier": "COMMANDS"
    },
    "topicSeparator": " "
  },
  "scripts": {
    "------------- toolchain -------------": "-------------",
    "format": "biome format --write",
    "lint": "biome lint --error-on-warnings",
    "checktypes": "tsc --noEmit",
    "check": "pnpm checktypes && pnpm lint",
    "test": "vitest",
    "------------- dev -------------": "-------------",
    "dev": "tsdown --watch",
    "------------- build -------------": "-------------",
    "build": "rm -rf dist && tsdown",
    "bundlesize": "pnpm build && npm pack --dry-run",
    "------------- publishing -------------": "-------------",
    "prepublish": "pnpm check && pnpm build"
  },
  "dependencies": {
    "@damiandb/pg": "workspace:*",
    "@electric-sql/pglite": "^0.3.15",
    "@electric-sql/pglite-tools": "^0.2.20",
    "@inquirer/prompts": "^8.3.0",
    "@oclif/core": "^4.8.3",
    "case": "^1.6.3",
    "chalk": "^5.6.2",
    "dbmate": "^2.31.0",
    "dotenv": "^17.3.1",
    "glob": "^13.0.6",
    "jiti": "^2.6.1",
    "log-symbols": "^7.0.1",
    "oclif": "4.22.81",
    "ora": "^9.3.0",
    "prettier": "^3.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@damiandb/config": "workspace:*",
    "@types/node": "25.3.3",
    "slonik-pglite-driver": "0.0.4",
    "tsdown": "0.21.0",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
