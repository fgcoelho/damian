{
  "name": "@damiandb/pg",
  "description": "PostgreSQL driver for Damian — type-safe SQL with Slonik",
  "author": "Fernando Coelho",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.1",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": "./dist/index.cjs"
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.cts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "------------- toolchain -------------": "-------------",
    "format": "biome format --write",
    "lint": "biome lint --error-on-warnings",
    "checktypes": "tsc --noEmit",
    "check": "pnpm checktypes && pnpm lint",
    "test": "vitest",
    "------------- dev -------------": "-------------",
    "dev": "tsdown --watch",
    "------------- build -------------": "-------------",
    "build": "rm -rf dist && tsdown",
    "bundlesize": "pnpm build && npm pack --dry-run",
    "------------- publishing -------------": "-------------",
    "prepublish": "pnpm check && pnpm build"
  },
  "dependencies": {
    "@slonik/pg-driver": "48.10.3",
    "@standard-schema/spec": "^1.1.0",
    "slonik": "48.10.3",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@electric-sql/pglite": "^0.3.15",
    "@types/node": "25.3.3",
    "slonik-pglite-driver": "0.0.4",
    "tsdown": "0.21.0-beta.2",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vite-node": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
