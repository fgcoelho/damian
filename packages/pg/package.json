{
  "name": "@damiandb/pg",
  "description": "PostgreSQL driver, built on top of Slonik, for Damian",
  "author": "Fernando Coelho",
  "homepage": "https://damiandb.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fgcoelho/damian.git"
  },
  "keywords": [
    "postgres",
    "driver",
    "damian"
  ],
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.6",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": "./dist/index.cjs"
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.cts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "------------- toolchain -------------": "-------------",
    "format": "biome format --write",
    "lint": "biome lint --error-on-warnings",
    "checktypes": "tsc --noEmit",
    "check": "pnpm checktypes && pnpm lint",
    "test": "vitest",
    "------------- dev -------------": "-------------",
    "dev": "tsdown --watch",
    "------------- build -------------": "-------------",
    "build": "rm -rf dist && tsdown",
    "bundlesize": "pnpm build && npm pack --dry-run",
    "------------- publishing -------------": "-------------",
    "prepublish": "pnpm check && pnpm build"
  },
  "dependencies": {
    "@slonik/pg-driver": "48.10.3",
    "slonik": "48.10.3"
  },
  "devDependencies": {
    "@damiandb/config": "workspace:*",
    "@biomejs/biome": "2.4.4",
    "@electric-sql/pglite": "^0.3.15",
    "@types/node": "25.3.3",
    "slonik-pglite-driver": "0.0.4",
    "tsdown": "0.21.0",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "^4.0.18"
  }
}
